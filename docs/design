```typescript
// lib/gdpr/scrubber.ts

import { SWEDISH_PATTERNS, ALL_SWEDISH_NAMES } from './patterns'

export interface ScrubberResult {
  scrubbedText: string
  replacements: Map<string, string>   // Original -> Placeholder (for UI preview)
  unmatchedCapitalized: string[]      // Capitalized words not replaced — may be undetected names
  stats: {
    namesReplaced: number
    piiTokensReplaced: number
  }
}

export interface ScrubberOptions {
  // Names the teacher has manually added — critical for non-Swedish names
  customNames?: string[]
}

export class GdprScrubber {
  private entityCounter = 0
  private entityMap = new Map<string, string>()

  private getPlaceholder(original: string, prefix: string = 'Elev'): string {
    const key = original.toLowerCase()
    if (!this.entityMap.has(key)) {
      this.entityCounter++
      this.entityMap.set(key, `[${prefix} ${this.entityCounter}]`)
    }
    return this.entityMap.get(key)!
  }

  scrub(text: string, options: ScrubberOptions = {}): ScrubberResult {
    this.entityCounter = 0
    this.entityMap.clear()

    let processed = text
    let namesReplaced = 0
    let piiTokensReplaced = 0
    const replacements = new Map<string, string>()

    // Step 1: Replace structural PII (personnummer, phone, email) first
    processed = processed.replace(SWEDISH_PATTERNS.personnummer, () => {
      piiTokensReplaced++
      return '[personnummer]'
    })
    processed = processed.replace(SWEDISH_PATTERNS.samordningsnummer, () => {
      piiTokensReplaced++
      return '[samordningsnummer]'
    })
    processed = processed.replace(SWEDISH_PATTERNS.phone, () => {
      piiTokensReplaced++
      return '[telefonnummer]'
    })
    processed = processed.replace(SWEDISH_PATTERNS.email, () => {
      piiTokensReplaced++
      return '[e-postadress]'
    })

    // Step 2: Build combined name list — built-in Swedish names + teacher-provided custom names
    // Custom names are trimmed and filtered to avoid empty strings
    const customNames = (options.customNames ?? [])
      .map(n => n.trim())
      .filter(n => n.length > 1)

    const allNames = [...ALL_SWEDISH_NAMES, ...customNames]

    // Step 3: Replace names — sort by length descending to avoid partial replacements
    // ("Elin" matched before "El" would be if "El" were a name)
    const sortedNames = allNames.sort((a, b) => b.length - a.length)

    for (const name of sortedNames) {
      const regex = new RegExp(`\\b${escapeRegex(name)}\\b`, 'gi')
      processed = processed.replace(regex, (match) => {
        const placeholder = this.getPlaceholder(match)
        if (!replacements.has(match)) {
          replacements.set(match, placeholder)
          namesReplaced++
        }
        return placeholder
      })
    }

    // Step 4: Detect remaining capitalized words that may be undetected names
    // Excludes sentence-initial words and known Swedish common nouns heuristically
    const unmatchedCapitalized = (processed.match(/(?<!\.\s)\b[A-ZÅÄÖ][a-zåäö]{2,}\b/g) ?? [])
      .filter(word => !SAFE_CAPITALIZED_WORDS.has(word))

    return {
      scrubbedText: processed,
      replacements,
      unmatchedCapitalized: [...new Set(unmatchedCapitalized)], // deduplicated
      stats: { namesReplaced, piiTokensReplaced }
    }
  }
}

// Words that are legitimately capitalized in Swedish pedagogical text
// and should not be flagged as potential names
const SAFE_CAPITALIZED_WORDS = new Set([
  'Måndag', 'Tisdag', 'Onsdag', 'Torsdag', 'Fredag', 'Lördag', 'Söndag',
  'Januari', 'Februari', 'Mars', 'April', 'Maj', 'Juni',
  'Juli', 'Augusti', 'September', 'Oktober', 'November', 'December',
  'Svenska', 'Matematik', 'Engelska', 'Historia', 'Biologi', 'Kemi',
  'Fysik', 'Musik', 'Idrott', 'Bild', 'Slöjd', 'Teknik',
  'Lgr', 'Skolverket', 'Unikum', 'Sverige', 'Stockholm',
])

function escapeRegex(str: string): string {
  return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
}
```

