// components/gdpr/GdprNameInput.tsx
'use client'

import { useState } from 'react'

interface Props {
  value: string[]
  onChange: (names: string[]) => void
}

export function GdprNameInput({ value, onChange }: Props) {
  const [inputValue, setInputValue] = useState('')

  const addName = () => {
    const trimmed = inputValue.trim()
    if (trimmed && !value.includes(trimmed)) {
      onChange([...value, trimmed])
    }
    setInputValue('')
  }

  const removeName = (name: string) => {
    onChange(value.filter(n => n !== name))
  }

  return (
    <div className="px-4 py-2 bg-[var(--ss-primary-light)] border-b 
                    border-[var(--ss-neutral-200)]">
      <p className="text-xs text-[var(--ss-neutral-800)] mb-1.5">
