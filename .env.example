# Copy this file to .env.local and fill in the blanks.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_PRO=
STRIPE_PRICE_ONETIME_30DAY=
# Runtime display/projection pricing. Defaults to 49/49/30 if omitted.
BILLING_MONTHLY_PRO_PRICE_SEK=49
BILLING_ONE_TIME_PASS_PRICE_SEK=49
BILLING_ONE_TIME_PASS_DURATION_DAYS=30
# Optional. Omit to use the Stripe SDK default pinned by the installed SDK.
STRIPE_API_VERSION=
# Keep false/blank in production unless you are deliberately running a test-mode staging deploy.
STRIPE_ALLOW_TEST_KEYS_IN_PRODUCTION=false

# Operations
APP_ENV=development
OPS_ALERT_WEBHOOK_URL=
# Optional. Set true only for isolated development/test environments.
HIBP_PASSWORD_CHECK_DISABLED=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
